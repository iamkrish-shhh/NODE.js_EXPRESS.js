<%- include('partials/head')  %>
<body style="font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif; margin: 0; padding: 24px; background-color: #fafafa; color: #1a1a1a;">
    <%- include('partials/nav')  %>
    <main style="max-width: 800px; margin: 80px auto; text-align: center; display: flex; flex-direction: column; align-items: center; gap: 16px;">
        <h1 style="color: #ff5a5f; font-size: 72px; margin: 0; font-weight: 800;">404</h1>
        <h2 style="color: #222222; font-size: 24px; margin: 0; font-weight: 600;">Oops! Page not found</h2>
        <p style="color: #717171; font-size: 16px; margin: 0 0 16px 0; max-width: 400px;">We can't seem to find the page you're looking for. Try going back to the home page.</p>
        <a href="/" style="text-decoration: none; background-color: #ff5a5f; color: white; border: none; padding: 12px 24px; border-radius: 8px; font-size: 14px; font-weight: 600; cursor: pointer; transition: background-color 0.2s ease, transform 0.1s ease;" onmouseover="this.style.backgroundColor='#e04b4f'" onmouseout="this.style.backgroundColor='#ff5a5f'" onmousedown="this.style.transform='scale(0.95)'" onmouseup="this.style.transform='scale(1)'">Go to Home</a>
    </main>
</body>
</html>